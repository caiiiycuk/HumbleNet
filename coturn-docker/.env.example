# Domain name pointing to your VPS (required)
DOMAIN=turn.example.com

# Email for Let's Encrypt certificate notifications (required)
EMAIL=admin@example.com

# Shared secret for TURN REST API authentication (required)
# Auto-generated by init.sh. To generate manually: openssl rand -hex 32
TURN_SECRET=

# Host port for ACME challenges. Default 80 (certbot standalone).
# Set to a non-standard port if proxying through a host nginx.
ACME_PORT=80

# Publish iceServers JSON to this URL every PUBLISH_INTERVAL seconds.
# Leave empty to disable.
# PUBLISH_URL=https://your-backend.com/iceServers
PUBLISH_URL=https://cloud.js-dos.com/gulp
PUBLISH_INTERVAL=60

# Relay port range (keep in sync with firewall rules)
RELAY_PORT_MIN=49152
RELAY_PORT_MAX=65535

# Public IP of your VPS (auto-detected if empty)
PUBLIC_IP=

# Credential TTL for TURN REST API authentication (default 2 hours)
CREDENTIAL_TTL=7200